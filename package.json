{
  "name": "optica",
  "author": "Leandro Valdez",
  "version": "1.0.0",
  "description": "Software para gestión de ópticas.",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev2": "next dev --hostname 192.168.100.136 -p 4000",
    "start": "next start",
    "start2": "next start --hostname 192.168.100.136 -p 4000",
    "build": "next build",
    "postinstall": "prisma generate",
    "export": "yarn build && next export -o _static",
    "seed": "tsx prisma/demo.ts",
    "lint": "eslint --ext .ts,.tsx .",
    "lint:fix": "eslint --fix --ext .ts,.tsx .",
    "prettier": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "clear-all": "rm -rf .next .swc _static out node_modules",
    "re-start": "rm -rf .next .swc _static out node_modules && yarn install && yarn dev",
    "re-build": "rm -rf .next .swc _static out node_modules && yarn install && yarn build"
  },
